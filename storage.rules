rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 커플 스토리지: 커플 멤버만 접근 가능
    match /couples/{coupleId}/{allPaths=**} {
      allow read, write: if request.auth != null &&
        request.auth.uid in firestore.get(
          /databases/(default)/documents/couples/$(coupleId)
        ).data.members;
    }
  }
}
