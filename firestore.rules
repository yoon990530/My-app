rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 커플에 속한 멤버인지 검증하는 함수
    function isMember(coupleId) {
      return request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
    }

    // 초대 코드: 인증된 유저라면 읽기 허용 (가입 전 코드 검증용)
    match /inviteCodes/{code} {
      allow read: if request.auth != null;
      allow write: if false; // 관리자만 생성 (Firebase Console)
    }

    // 커플 문서: 멤버만 읽기, 멤버가 자신의 UID를 추가하는 경우만 쓰기
    match /couples/{coupleId} {
      allow read: if isMember(coupleId);
      allow update: if request.auth != null &&
        // members 배열에 본인 UID 추가만 허용
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'startDate']) &&
        (
          // members 업데이트: 본인 UID 추가만 가능, 최대 2명
          !('members' in request.resource.data.diff(resource.data).affectedKeys()) ||
          (
            request.auth.uid in request.resource.data.members &&
            request.resource.data.members.size() <= 2
          )
        );

      // 게시물 서브컬렉션
      match /posts/{postId} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId) &&
          request.resource.data.authorId == request.auth.uid;
        allow update: if isMember(coupleId);
        allow delete: if isMember(coupleId) &&
          resource.data.authorId == request.auth.uid;
      }

      // 메시지 서브컬렉션
      match /messages/{messageId} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId) &&
          request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false; // 메시지 수정/삭제 불가
      }

      // 기념일 서브컬렉션
      match /anniversaries/{anniversaryId} {
        allow read, write: if isMember(coupleId);
      }
    }

    // 유저 문서: 본인만 읽기/쓰기
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
